# ── Backend URL ────────────────────────────────────────────────
# Set this to your Railway backend service URL in production.
# Leave unset for local dev (falls back to http://localhost:3000).
# NEXT_PUBLIC_ prefix makes it available on both server and client.
NEXT_PUBLIC_BACKEND_URL=https://your-backend.up.railway.app

# ── Clerk Authentication ────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_live_YOUR_KEY_HERE
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/feed
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/feed

# ── Cloudflare Turnstile (bot protection on Creator Sign-Up) ────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# ── Admin dashboard (/admin) ─────────────────────────────────────
# The signed-in Clerk user's email must match this exactly to access
# the dashboard. Must equal the backend's ADMIN_EMAIL value.
NEXT_PUBLIC_ADMIN_EMAIL=your_admin_email@zuva.tv
