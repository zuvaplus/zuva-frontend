# ── Backend URL (server-side only — not exposed to browser) ───
# Set this to your Railway backend service URL in production.
# Leave unset for local dev (defaults to http://localhost:3000).
BACKEND_URL=https://your-backend.up.railway.app

# ── No other env vars required ────────────────────────────────
# The frontend proxies all /api/* requests through Next.js rewrites,
# so the backend URL is never exposed to the browser.
